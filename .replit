# Replit configuration for RBC Quest
# ---------------------------------------------------------------------------
# Press "Run" to preview in the Replit webview. To publish at rbcquest.com,
# use Deploy → Static (publicDir "."), then attach the custom domain.

run = "node server.js"
entrypoint = "index.html"
modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

# Static deployment serves the files directly — no server process needed.
[deployment]
deploymentTarget = "static"
publicDir = "."

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 node server.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
expertMode = true
